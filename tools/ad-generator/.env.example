# LLM — Vertex AI (uses same auth as zevo-site backend)
VERTEX_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_MODEL_HEAVY=gemini-2.5-pro
VERTEX_MODEL_FAST=gemini-2.5-flash

# Local auth: path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=
# OR: inline JSON (for cloud/Vercel) — use ONE of the two
# GOOGLE_CLOUD_CREDENTIALS={"type":"service_account",...}

# Phase 4 (asset gathering) — multi-provider stock video.
# Configure any subset; the pipeline auto-uses whichever keys are present.
PEXELS_API_KEY=
# Pixabay videos (free, commercial-use): https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# Min Gemini score (0-100) a stock clip must hit on impact + narrative fit to be
# accepted; below this the pipeline retries with new queries/providers. Default 65.
STOCK_SCORE_THRESHOLD=65

# Phase 5 (voiceover) — falls back to macOS `say` if missing
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_TR=
ELEVENLABS_VOICE_EN=

# Phase 7 (Meta auto-upload) — leave blank for dry-run
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxxxx
META_PAGE_ID=
META_CAMPAIGN_ID=
META_AD_SET_ID=
META_DESTINATION_URL=https://zevoapp.com
